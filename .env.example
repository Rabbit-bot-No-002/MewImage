MEW_IMAGE_LISTEN=127.0.0.1:3000
MEW_IMAGE_DATABASE_URL=sqlite://./data/mew-image.db?mode=rwc
MEW_IMAGE_FRONTEND_DIST=./frontend/dist-app
MEW_IMAGE_SESSION_SECURE=false

# 允许带 Cookie 的前端来源，多个值用英文逗号分隔
# 本地开发推荐保留 3000 和 8080 两类地址
MEW_IMAGE_ALLOWED_WEB_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:8080,http://localhost:8080

# 游客代理是否可用。true 表示“游客本地 + 受限代理模式”
MEW_IMAGE_ENABLE_GUEST_PROXY=true

# 是否要求自定义服务商必须登录后才能使用
MEW_IMAGE_REQUIRE_LOGIN_FOR_CUSTOM_PROVIDER=true

# 是否强制第三方上游命中白名单。默认 false，更适合常见 API 中转站场景
MEW_IMAGE_ENFORCE_PROVIDER_HOST_WHITELIST=false

# 可选白名单，多个值用英文逗号分隔。开启强制白名单时才会限制第三方上游
# 无论是否开启白名单，后端都会拒绝 localhost、私网 IP、链路本地地址
MEW_IMAGE_TRUSTED_PROVIDER_HOSTS=

# 对象存储。未配置时，游客本地生图仍可用，但登录态远程资源上传/同步图片不可用
MEW_IMAGE_S3_BUCKET=mew-image
MEW_IMAGE_S3_REGION=us-east-1
MEW_IMAGE_S3_ENDPOINT=http://127.0.0.1:9000
MEW_IMAGE_S3_ACCESS_KEY=minioadmin
MEW_IMAGE_S3_SECRET_KEY=minioadmin
