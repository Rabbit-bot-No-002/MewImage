# ============================================================
# Docker Compose 基础设置
# ============================================================

# Docker Hub 镜像。需要固定版本时可改成 mewlab/mewimage:1.0.0
MEW_DOCKER_IMAGE=mewlab/mewimage:latest
MEW_CONTAINER_NAME=mew-image
# 该端口会映射到容器内部固定的 3000 端口。
MEW_HOST_PORT=3188
MEW_MEMORY_LIMIT=1g

# ============================================================
# 首次部署必须修改
# ============================================================

# 用于设备/IP 摘要和认证保护，必须使用固定强随机值。
# 生成命令：openssl rand -hex 32
MEW_AUTH_SECRET=

# 首个管理员初始化口令。首次注册管理员时填写，建议使用密码管理器生成。
# 生成命令：openssl rand -base64 32
MEW_ADMIN_TOKEN=

# 允许访问后端的网页来源，多个地址使用英文逗号分隔，末尾不要加 /。
# 公网 HTTPS 示例：https://img.example.com
# 直接通过服务器端口访问示例：http://你的服务器IP:3188
# 下方默认值同时兼容 Docker 本机访问和前端开发端口；正式上线应只保留真实站点地址。
MEW_ALLOWED_ORIGINS=http://127.0.0.1:3188,http://localhost:3188,http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:8080,http://localhost:8080

# ============================================================
# HTTPS 与反向代理
# ============================================================

# 正式 HTTPS 域名部署改为 true；直接使用 HTTP/IP 测试时保持 false。
MEW_SESSION_SECURE=false

# 只有后端无法绕过 Nginx/NPM 直接从公网访问时才能设为 true。
MEW_TRUST_PROXY_HEADERS=false

# 是否允许通过初始化口令创建第一个管理员。
MEW_ALLOW_ADMIN_SETUP=true

# ============================================================
# 注册、登录与密码哈希限制
# ============================================================

# 同一浏览器设备最多成功注册账号数；0 表示关闭。
MEW_REGISTER_DEVICE_LIMIT=3

# 同一 IP 每 86400 秒最多尝试注册 10 次。
MEW_REGISTER_IP_LIMIT=10
MEW_REGISTER_WINDOW_SECONDS=86400

# 同一 IP 每 600 秒最多尝试登录 20 次。
MEW_LOGIN_IP_LIMIT=20
MEW_LOGIN_WINDOW_SECONDS=600

# 同一账号连续输错 5 次密码后锁定 300 秒。
MEW_LOGIN_FAILURE_LIMIT=5
MEW_LOGIN_LOCK_SECONDS=300

# 同时运行的 Argon2 密码哈希/校验任务数，小型服务器建议保持 2。
MEW_AUTH_HASH_CONCURRENCY=2

# ============================================================
# 游客代理与第三方服务商
# ============================================================

# 游客可使用瞬时生成代理，但工作区和图片不会写入服务器存储。
MEW_GUEST_PROXY=true

# 高级 CustomHttp 服务商默认要求登录。
MEW_CUSTOM_PROVIDER_LOGIN=true

# 默认允许公网第三方中转站，同时始终拒绝本机、私网和链路本地地址。
# 若只允许固定上游，可设为 true，并填写 MEW_TRUSTED_HOSTS。
MEW_ENFORCE_HOST_WHITELIST=false
MEW_TRUSTED_HOSTS=

# ============================================================
# 登录用户图片存储
# ============================================================

# local：保存到宿主机 ./data/assets，个人部署推荐。
# s3：使用下方 S3 兼容对象存储。
# disabled：禁用云端图片存储，游客本地模式仍可使用。
MEW_ASSET_STORE=local

# 只有 MEW_ASSET_STORE=s3 时才需要填写。
MEW_S3_BUCKET=
MEW_S3_REGION=us-east-1
MEW_S3_ENDPOINT=
MEW_S3_ACCESS_KEY=
MEW_S3_SECRET_KEY=
